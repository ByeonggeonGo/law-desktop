<Window x:Class="LawDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LawDesktop"
        mc:Ignorable="d"
        Title="AI Local Law Assistant (Agy CLI + Law MCP)" 
        Height="768" Width="1280"
        Background="#0F172A"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- WPF Built-in Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        
        <!-- ScrollBar Styling -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title / Settings area -->
            <RowDefinition Height="60"/>
            <!-- Main Content Area -->
            <RowDefinition Height="*"/>
            <!-- Status Bar -->
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- 1. Header Area -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚖️ Local Law Assistant" Foreground="#F8FAFC" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="with Antigravity CLI &amp; Korea Law MCP" Foreground="#94A3B8" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Settings & Configuration Form -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OC Key:" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                    <TextBox x:Name="OcTextBox" Width="120" Height="28" VerticalContentAlignment="Center" Background="#0F172A" Foreground="#F1F5F9" BorderBrush="#475569" Padding="5,0"/>
                    
                    <TextBlock Text="Model:" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="12" Margin="15,0,6,0"/>
                    <ComboBox x:Name="ModelComboBox" Width="160" Height="28" Background="#0F172A" Foreground="#F1F5F9" BorderBrush="#475569" SelectedIndex="0" Margin="0,0,10,0">
                        <ComboBoxItem Content="gemini-3.5-flash"/>
                        <ComboBoxItem Content="gemini-3.5-pro"/>
                    </ComboBox>
                    
                    <Button Content="Apply" Width="60" Height="28" Click="ApplySettings_Click" Background="#38BDF8" Foreground="#0F172A" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Main Content Area (Split Pane) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- 2.1. Left Area: Chat Interface -->
            <Grid Grid.Column="0" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chat History ScrollViewer -->
                <ScrollViewer Grid.Row="0" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                    <ItemsControl x:Name="ChatItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,5,0,10" Padding="12" CornerRadius="8" BorderThickness="1" MaxWidth="560" 
                                        Background="{Binding BubbleBackground}"
                                        BorderBrush="{Binding BubbleBorder}"
                                        HorizontalAlignment="{Binding Alignment}">
                                    
                                    <StackPanel>
                                        <!-- Sender Header -->
                                        <TextBlock Text="{Binding Sender}" FontWeight="Bold" Foreground="#F8FAFC" FontSize="11" Margin="0,0,0,4"/>
                                        
                                        <!-- Message Content -->
                                        <TextBox Text="{Binding Content}" TextWrapping="Wrap" IsReadOnly="True" Background="Transparent" Foreground="#F1F5F9" BorderThickness="0" FontSize="13" FontFamily="Segoe UI" CaretBrush="Transparent"/>
                                        
                                        <!-- Citation Verification Summary Guard -->
                                        <Border Margin="0,8,0,0" Padding="6" CornerRadius="4" Background="#0F172A" Visibility="{Binding HasGuardSummary, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Verification Status Icon -->
                                                <TextBlock Foreground="#22C55E" FontWeight="Bold" Margin="0,0,6,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="✓"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHallucinated}" Value="True">
                                                                    <Setter Property="Text" Value="✗"/>
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsPartialVerified}" Value="True">
                                                                    <Setter Property="Text" Value="⚠"/>
                                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding GuardSummary}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Extracted Citation Link Buttons -->
                                        <ItemsControl ItemsSource="{Binding Citations}" Margin="0,8,0,0" Visibility="{Binding HasCitations, Converter={StaticResource BoolToVisConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Margin="0,2,0,2" Click="CitationLink_Click" Tag="{Binding}" Background="#334155" BorderBrush="#475569" Foreground="#38BDF8" HorizontalAlignment="Left" Padding="6,4" Cursor="Hand">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="📄 " FontSize="11"/>
                                                            <TextBlock Text="{Binding Type}" FontWeight="Bold" FontSize="11" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding Title}" FontSize="11" TextDecorations="Underline"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input Panel -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="InputTextBox" Grid.Column="0" Height="45" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" BorderThickness="1" Padding="10,8" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" KeyDown="InputTextBox_KeyDown" VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    
                    <Button Content="Send" Grid.Column="1" Margin="8,0,0,0" Height="45" Click="SendButton_Click" Background="#38BDF8" Foreground="#0F172A" FontWeight="Bold" FontSize="13" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>

            <!-- 2.2. Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#334155" ShowsPreview="True"/>

            <!-- 2.3. Right Area: Document Viewer -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="15">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock x:Name="ViewerTitleText" Text="Law / Precedent Document Viewer" Foreground="#F8FAFC" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="ViewerSubtitleText" Text="Click on any legal citation link in the chat to load its full text details here." Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0"/>
                        <Separator Background="#334155" Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- Document Content TextBox -->
                    <TextBox Grid.Row="1" x:Name="ViewerContentTextBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#334155" Padding="12" FontSize="12" FontFamily="Segoe UI">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Grid>
            </Border>
        </Grid>

        <!-- 3. Footer / Status Bar -->
        <Border Grid.Row="2" Background="#0F172A" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="Ready..." Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="DiagnosticsText" Text="Diagnosing agy cli status..." Foreground="#F59E0B" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
